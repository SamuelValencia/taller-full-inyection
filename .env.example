# Variables de entorno - Copiar a .env y completar (NUNCA subir .env a git)

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DJANGO_SETTINGS_MODULE=fuel_injection.settings.development

# ── Desarrollo local ───────────────────────────────────────────
DB_NAME=fuel_injection
DB_USER=postgres
DB_PASSWORD=tu_password_local
DB_HOST=localhost
DB_PORT=5432

# ── Produccion (Supabase) ──────────────────────────────────────
# Cuando despliegues en Render, usa DATABASE_URL en lugar de las variables DB_*
# DATABASE_URL=postgresql://user:password@db.xxxx.supabase.co:5432/postgres

ALLOWED_HOSTS=localhost,127.0.0.1
# En produccion: ALLOWED_HOSTS=tu-app.onrender.com

CSRF_TRUSTED_ORIGINS=
# En produccion: CSRF_TRUSTED_ORIGINS=https://tu-app.onrender.com

# ── Email (Resend SMTP) ────────────────────────────────────────
# Desarrollo: mantener console para ver emails en terminal
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Produccion: cambiar a smtp y completar las variables de Resend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_xxxxxxxxxxxxxxxxxxxx
# El FROM debe ser un dominio verificado en Resend (o usar onboarding@resend.dev para pruebas)
DEFAULT_FROM_EMAIL=Fuel Injection <onboarding@resend.dev>

# ── WhatsApp (opcional) ────────────────────────────────────────
WHATSAPP_PROVIDER=
WHATSAPP_ACCOUNT_SID=
WHATSAPP_AUTH_TOKEN=
WHATSAPP_FROM_NUMBER=
WHATSAPP_META_TOKEN=
WHATSAPP_META_PHONE_NUMBER_ID=

# ── Info del taller ────────────────────────────────────────────
TALLER_NOMBRE=Fuel Injection
TALLER_TELEFONO=+593 99 999 9999
TALLER_DIRECCION=Guayaquil, Ecuador
